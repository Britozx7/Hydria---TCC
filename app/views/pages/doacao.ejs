<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Doações</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="..\css\doacao.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"
    />
  </head>
  <body>
    <main>
      <a href="/"
        ><button class="btn-01"><i class="fas fa-arrow-left"></i></button
      ></a>

      <%
          const msgErro = { valorDigitado:'', valorSelecionado:'' }
          const cssErro = { valorDigitado:'', valorSelecionado:'' }
          if (typeof valores === 'undefined') { valores = { valorDigitado:'' } } {
            if (typeof listaErros !== 'undefined' && listaErros && listaErros.errors){
              listaErros.errors.forEach((erro) => {
                if (erro.path === 'valorDigitado') {
                  msgErro.valorDigitado = erro.msg
                  cssErro.valorDigitado = 'erro-form'
                }
                if(erro.path === 'valorSelecionado') {
                  msgErro.valorSelecionado = erro.msg
                  cssErro.valorSelecionado = 'erro-form'
                }
              })
            }
          }
          
      %>

      <section class="selection">
        <form action="select" method="post">
          <label class="topic-tittle" for="text">
            <b>Selecionar Valor</b>
          </label>
          <span class="spanErro"> <%= msgErro.valorSelecionado %> </span>
          <section class="selection-btn">
            <button type="button" class="btn" id="valor" data-valor="25">R$25</button>
            <button type="button" class="btn" id="valor" data-valor="50">R$50</button>
            <button type="button" class="btn" id="valor" data-valor="75">R$75</button>
            <button type="button" class="btn" id="valor" data-valor="100">R$100</button>
            <button type="button" class="btn" id="valor" data-valor="125">R$125</button>
            <button type="button" class="btn" id="valor" data-valor="150">R$150</button>
          </section>
          <label class="content" for="text">
          Digite o valor que gostaria de doar:
          </label>
          <br>
          <input class="input" value="<%= valores.valorDigitado %>" type="text" name="valorDigitado" id="inputManual" placeholder="Ex: 75">
          <span class="span2"><%= msgErro.valorDigitado %></span>
          <span
            class="error-message"
            id="inputManual-error"
            role="alert"
            aria-live="polite"
          ></span>
          <input type="hidden" name="valorSelecionado" id="valorSelecionado">
          <button type="submit" class="btn-02">Próximo</button>
        </form>
      </section>

